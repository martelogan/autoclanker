{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/eval_result.schema.json",
  "title": "BayesLayerEvalResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "era_id",
    "candidate_id",
    "intended_genotype",
    "realized_genotype",
    "patch_hash",
    "status",
    "seed",
    "runtime_sec",
    "peak_vram_mb",
    "raw_metrics",
    "delta_perf",
    "utility",
    "replication_index"
  ],
  "properties": {
    "era_id": { "type": "string", "minLength": 1 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "intended_genotype": {
      "type": "array",
      "items": { "$ref": "#/$defs/GeneStateRef" }
    },
    "realized_genotype": {
      "type": "array",
      "items": { "$ref": "#/$defs/GeneStateRef" }
    },
    "patch_hash": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["valid", "compile_fail", "runtime_fail", "oom", "timeout"]
    },
    "seed": { "type": "integer", "minimum": 0 },
    "runtime_sec": { "type": "number", "minimum": 0 },
    "peak_vram_mb": { "type": "number", "minimum": 0 },
    "raw_metrics": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "integer", "string", "boolean", "null"]
      }
    },
    "delta_perf": { "type": "number" },
    "utility": { "type": "number" },
    "replication_index": { "type": "integer", "minimum": 0 },
    "stdout_digest": { "type": "string" },
    "stderr_digest": { "type": "string" },
    "artifact_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failure_metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "eval_contract": {
      "$ref": "#/$defs/EvalContractSnapshot"
    },
    "execution_metadata": {
      "$ref": "#/$defs/EvalExecutionMetadata"
    }
  },
  "$defs": {
    "GeneStateRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gene_id", "state_id"],
      "properties": {
        "gene_id": { "type": "string", "minLength": 1 },
        "state_id": { "type": "string", "minLength": 1 }
      }
    },
    "EvalContractSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_digest",
        "benchmark_tree_digest",
        "eval_harness_digest",
        "adapter_config_digest",
        "environment_digest"
      ],
      "properties": {
        "contract_digest": { "type": "string", "minLength": 1 },
        "benchmark_tree_digest": { "type": "string", "minLength": 1 },
        "eval_harness_digest": { "type": "string", "minLength": 1 },
        "adapter_config_digest": { "type": "string", "minLength": 1 },
        "environment_digest": { "type": "string", "minLength": 1 },
        "measurement_mode": {
          "type": "string",
          "enum": ["exclusive", "parallel_ok"]
        },
        "stabilization_mode": {
          "type": "string",
          "enum": ["off", "soft"]
        },
        "lease_scope": { "type": "string", "minLength": 1 },
        "workspace_snapshot_id": { "type": "string", "minLength": 1 },
        "workspace_snapshot_mode": { "type": "string", "minLength": 1 },
        "captured_paths": {
          "type": "object",
          "additionalProperties": true
        },
        "captured_at": { "type": "string", "minLength": 1 }
      }
    },
    "EvalExecutionMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["isolation_mode"],
      "properties": {
        "isolation_mode": {
          "type": "string",
          "enum": ["git_worktree", "copy", "fixture"]
        },
        "workspace_root": { "type": "string", "minLength": 1 },
        "workspace_snapshot_id": { "type": "string", "minLength": 1 },
        "contract_digest": { "type": "string", "minLength": 1 },
        "measurement_mode": {
          "type": "string",
          "enum": ["exclusive", "parallel_ok"]
        },
        "stabilization_mode": {
          "type": "string",
          "enum": ["off", "soft"]
        },
        "lease_scope": { "type": "string", "minLength": 1 },
        "lease_acquired": { "type": "boolean" },
        "lease_wait_sec": { "type": "number", "minimum": 0 },
        "noisy_system": { "type": "boolean" },
        "loadavg_1m_before": { "type": "number", "minimum": 0 },
        "loadavg_1m_after": { "type": "number", "minimum": 0 },
        "stabilization_delay_sec": { "type": "number", "minimum": 0 }
      }
    }
  }
}
