# Optional local environment for autoclanker.
#
# Copy this file to `.env.local` for machine-local secrets and overrides:
#
#   cp .env.example .env.local
#
# `.env.local` is gitignored. Keep real credentials there, not in `.env.example`.

# Enable billed live-provider tests.
# AUTOCLANKER_ENABLE_LLM_LIVE=1

# Anthropic-backed canonicalization.
# Prefer the AUTOCLANKER_ namespaced variable for project-local clarity.
# AUTOCLANKER_ANTHROPIC_API_KEY=
# ANTHROPIC_API_KEY=

# Optional upstream checkout overrides for live adapter smoke runs.
# AUTOCLANKER_LIVE_AUTORESEARCH_PATH=
# AUTOCLANKER_LIVE_CEVOLVE_PATH=

# Optional alternate dotenv file for `scripts/test-live.sh`.
# AUTOCLANKER_LLM_ENV_FILE=
